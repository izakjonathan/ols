# Set these in Vercel Project Settings > Environment Variables
# Use the Supabase project you already have, so you do not need another paid project.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-PUBLIC-KEY

# Optional. Leave as default unless you want multiple systems in the same Supabase project.
NEXT_PUBLIC_SUPABASE_TABLE=oland_service_state
NEXT_PUBLIC_SUPABASE_STATE_ID=main
